# tinder-for-dogs/.envrc

# Load global AI config
if [ ! -f .env.cached ] || [ $(find .env.cached -mtime +1) ]; then
    . "$HOME/.ai/.envrc"
fi
source .env.cached

# Project-specific overrides
export PROJECT_NAME="tinder-for-dogs"
export LANGFUSE_PROJECT="whysoserious"  # Matches docker-compose init

# Spring Boot config
export POSTGRES_URL="jdbc:postgresql://localhost:5433/tinderfordogs"
export POSTGRES_USERNAME="postgres"
