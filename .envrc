# tinder-for-dogs/.envrc

# Load global AI config
source_env ~/.ai

# Project-specific overrides
export PROJECT_NAME="tinder-for-dogs"
export LANGFUSE_PROJECT="whysoserious"  # Matches docker-compose init

# Spring Boot config
export SPRING_DATASOURCE_URL="jdbc:postgresql://localhost:5432/tinderfordogs"
export SPRING_DATASOURCE_USERNAME="postgres"
export SPRING_DATASOURCE_PASSWORD="${POSTGRES_PASSWORD}"